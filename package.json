{
  "name": "@showlotus/opencode-image-vision",
  "version": "1.0.4",
  "description": "OpenCode plugin that adds vision capabilities to text-only LLMs by analyzing pasted images via vision AI providers",
  "type": "module",
  "packageManager": "pnpm@8.11.0",
  "main": "src/index.js",
  "bin": {
    "opencode-image-vision": "./src/index.js"
  },
  "exports": {
    ".": "./plugin/index.js",
    "./plugin": "./plugin/index.js",
    "./server": "./plugin/index.js"
  },
  "files": [
    "src/",
    "shared/",
    "plugin/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/showlotus/opencode-image-vision.git"
  },
  "homepage": "https://github.com/showlotus/opencode-image-vision",
  "bugs": {
    "url": "https://github.com/showlotus/opencode-image-vision/issues"
  },
  "author": "showlotus",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "vision",
    "image-analysis",
    "glm",
    "zhipuai"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18"
  }
}
